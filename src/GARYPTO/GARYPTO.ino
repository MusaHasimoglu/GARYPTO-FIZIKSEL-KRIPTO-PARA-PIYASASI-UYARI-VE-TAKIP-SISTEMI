void numpadDokunmatikKontrol(uint16_t x, uint16_t y) {
  bool basildi = false;
  if (x > 30 && x < 100) {
    if (y > 80 && y < 130) { girilenRakamStr += "1"; basildi = true; }
    else if (y > 140 && y < 190) { girilenRakamStr += "4"; basildi = true; }
    else if (y > 200 && y < 250) { girilenRakamStr += "7"; basildi = true; }
    else if (y > 260 && y < 310) { girilenRakamStr += "."; basildi = true; }
  }
  else if (x > 110 && x < 180) {
    if (y > 80 && y < 130) { girilenRakamStr += "2"; basildi = true; }
    else if (y > 140 && y < 190) { girilenRakamStr += "5"; basildi = true; }
    else if (y > 200 && y < 250) { girilenRakamStr += "8"; basildi = true; }
    else if (y > 260 && y < 310) { girilenRakamStr += "0"; basildi = true; }
  }
  else if (x > 190 && x < 260) {
    if (y > 80 && y < 130) { girilenRakamStr += "3"; basildi = true; }
    else if (y > 140 && y < 190) { girilenRakamStr += "6"; basildi = true; }
    else if (y > 200 && y < 250) { girilenRakamStr += "9"; basildi = true; }
    else if (y > 260 && y < 310) { 
      if (girilenRakamStr.length() > 0) { girilenRakamStr.remove(girilenRakamStr.length() - 1); }
      basildi = true; 
    }
  }
  // GÜNCELLEME 2'NİN DEVAMI: GERİ VE ONAY KOORDİNAT KONTROLLERİ
  else if (x > 280 && x < 450) {
    if (y > 80 && y < 150) {
      kisaBip();
      canliEkranaGec(); // GERİ butonuna basıldı, değer kaydetmeden dön
      return;
    }
    else if (y > 160 && y < 310) {
      kisaBip();
      if (girilenRakamStr.length() > 0) {
        if (numpadModu == 1) { 
          hedefFiyat = girilenRakamStr.toFloat(); hedefFiyatStr = girilenRakamStr; alarmKurulduMu = true; alarmTetiklendiMi = false;
          if (hedefFiyat > anlikFiyat) { alarmYonu = 1; } else { alarmYonu = -1; } 
        } 
        else if (numpadModu == 2) { 
          degisimSiniri = girilenRakamStr.toFloat(); 
        }
        onaySesiCal(); canliEkranaGec(); 
      }
      return;
    }
  }
  
  if (basildi) {
    kisaBip();
    if (girilenRakamStr.length() > 10) girilenRakamStr = girilenRakamStr.substring(0, 10);
    numpadEkraniGuncelle();
  }
}

void kisaBip() { tone(BUZZER_PIN, 2000, 50); }
void onaySesiCal() { tone(BUZZER_PIN, 1000, 100); delay(100); tone(BUZZER_PIN, 1500, 100); delay(100); tone(BUZZER_PIN, 2000, 200); }