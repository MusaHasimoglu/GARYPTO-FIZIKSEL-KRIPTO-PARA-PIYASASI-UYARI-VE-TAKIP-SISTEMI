void setup() {
  Serial.begin(115200);
  pinMode(BUZZER_PIN, OUTPUT);
  tft.init();
  tft.setRotation(1); 
  tft.setTouch(calData); 

  // Servo Kurulumu 
  ESP32PWM::allocateTimer(0);
  ESP32PWM::allocateTimer(1);
  servoYesil.setPeriodHertz(50);
  servoKirmizi.setPeriodHertz(50);
  
  // Yeşil motor ters yönde çalışması için 90'da başlatılıyor
  servoYesil.attach(SERVO_YESIL_PIN, 500, 2400);
  servoYesil.write(90); 
  delay(300); 
  
  servoKirmizi.attach(SERVO_KIRMIZI_PIN, 500, 2400);
  servoKirmizi.write(0); 
  delay(300); 
  
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_ORANGE); tft.setTextSize(3); tft.setTextDatum(MC_DATUM);
  tft.drawString("GARYPTO", tft.width()/2, tft.height()/2 - 30);
  tft.setTextColor(TFT_WHITE); tft.setTextSize(2);
  tft.drawString("Wi-Fi Baglaniyor...", tft.width()/2, tft.height()/2 + 20);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); }
  
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_GREEN);
  tft.drawString("INTERNETE BAGLANDI!", tft.width()/2, tft.height()/2);
  kisaBip(); delay(1000);
  
  anaMenuyuCiz();
}

void loop() {
  uint16_t x, y;

  if (aktifSayfa == 1) {
    if (millis() - sonGuncelleme > 5000) {
      fiyatCekVeYazdir();
      sonGuncelleme = millis();
    }
    // GÜNCELLEME 1: Alarm tetiklendiğinde artık servo motorlar çağrılmıyor
    if (alarmKurulduMu && !alarmTetiklendiMi && anlikFiyat > 0) {
      if (alarmYonu == 1 && anlikFiyat >= hedefFiyat) { 
        alarmTetikle();
      } 
      if (alarmYonu == -1 && anlikFiyat <= hedefFiyat) { 
        alarmTetikle();
      } 
    }
  }

  if (tft.getTouch(&x, &y)) {
    if (aktifSayfa == 0) {
      if (x > 20 && x < 240 && y > 70 && y < 180) { kisaBip(); seciliCoin = "BTC"; apiSymbol = "BTCUSDT"; canliEkranaGec(); }
      else if (x > 240 && x < 460 && y > 70 && y < 180) { kisaBip(); seciliCoin = "ETH"; apiSymbol = "ETHUSDT"; canliEkranaGec(); }
      else if (x > 130 && x < 350 && y > 190 && y < 300) { kisaBip(); seciliCoin = "BNB"; apiSymbol = "BNBUSDT"; canliEkranaGec(); }
    }
    else if (aktifSayfa == 1) {
      if (x > 330 && x < 460 && y > 240 && y < 300) { kisaBip(); numpadModu = 1; numpadEkraninaGec(); } 
      else if (x > 170 && x < 310 && y > 240 && y < 300) { kisaBip(); numpadModu = 2; numpadEkraninaGec(); } 
      else if (x > 20 && x < 150 && y > 240 && y < 300) { kisaBip(); anaMenuyuCiz(); } 
    }
    else if (aktifSayfa == 2) {
      numpadDokunmatikKontrol(x, y);
    }
    delay(200); 
  }
}

// ================= API VE MEKANİK FONKSİYONLAR =================
void fiyatCekVeYazdir() {
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    http.begin("https://api.binance.com/api/v3/ticker/price?symbol=" + apiSymbol);
    if (http.GET() > 0) {
      String payload = http.getString();
      JsonDocument doc;
      deserializeJson(doc, payload);
      float yeniFiyat = doc["price"].as<float>();

      if (oncekiFiyat == 0.0) { 
        oncekiFiyat = yeniFiyat; 
      }

      // Merkez noktası (oncekiFiyat) ile anlık gelen fiyat arasındaki 5 saniyelik fark
      float fark = yeniFiyat - oncekiFiyat;

      // === 1. ADIM: ÖNCE YENİ FİYATI EKRANA YAZDIR ===
      anlikFiyat = yeniFiyat;
      tft.fillRect(10, 90, 460, 65, TFT_BLACK); 
      tft.setTextSize(5); tft.setTextColor(TFT_GREEN, TFT_BLACK); tft.setTextDatum(MC_DATUM);
      tft.drawString("$" + String(anlikFiyat, 3), tft.width()/2, 120); 

      // === 2. ADIM: SONRA BAYRAKLARI VE ALARMI TETİKLE ===
      // Motorlar sadece son 5 saniye içindeki fark limiti aşarsa kalkar
      if (fabs(fark) >= degisimSiniri) {
        if (fark > 0) {
          bayrakKaldir(1);  
        } else {
          bayrakKaldir(-1); 
        }
      }

      // === 3. ADIM: MERKEZ NOKTASINI HER 5 SANİYEDE BİR GÜNCELLE ===
      // Alarm çalsa da çalmasa da, bir sonraki 5 saniye için merkez noktamız artık bu yeni fiyattır.
      oncekiFiyat = yeniFiyat; 

    } else {
      tft.fillRect(10, 90, 460, 65, TFT_BLACK); 
      tft.setTextSize(3); tft.setTextColor(TFT_RED, TFT_BLACK); tft.setTextDatum(MC_DATUM);
      tft.drawString("BAGLANTI HATASI!", tft.width()/2, 120);
    }
    http.end();
  } 
}

void bayrakKaldir(int yon) {
  if (yon == 1) { 
    tft.fillRect(0, 0, tft.width(), 80, TFT_DARKGREEN);
    tft.setTextColor(TFT_WHITE); tft.setTextSize(3); tft.setTextDatum(MC_DATUM);
    tft.drawString("ANI YUKSELIS!", tft.width()/2, 40);
    
    // Yeşil bayrak 90'dan 0'a ters kalkar
    for (int pos = 90; pos >= 0; pos -= 2) { servoYesil.write(pos); delay(15); }
    for(int i=0; i<4; i++) { tone(BUZZER_PIN, 1500, 200); delay(200); tone(BUZZER_PIN, 1000, 200); delay(200); }
    for (int pos = 0; pos <= 90; pos += 2) { servoYesil.write(pos); delay(15); }

  } else if (yon == -1) { 
    tft.fillRect(0, 0, tft.width(), 80, TFT_RED);
    tft.setTextColor(TFT_WHITE); tft.setTextSize(3); tft.setTextDatum(MC_DATUM);
    tft.drawString("ANI DUSUS!", tft.width()/2, 40);
    
    // Kırmızı bayrak standart 0'dan 90'a kalkar
    for (int pos = 0; pos <= 90; pos += 2) { servoKirmizi.write(pos); delay(15); }
    for(int i=0; i<4; i++) { tone(BUZZER_PIN, 500, 200); delay(200); tone(BUZZER_PIN, 300, 200); delay(200); } 
    for (int pos = 90; pos >= 0; pos -= 2) { servoKirmizi.write(pos); delay(15); }
  }
  
  tft.fillRect(0, 0, tft.width(), 80, TFT_BLACK);
  tft.setTextColor(TFT_WHITE); tft.setTextSize(3);
  tft.drawString(seciliCoin + " CANLI TAKIP", tft.width()/2, 40);
}

void alarmTetikle() {
  alarmTetiklendiMi = true; alarmKurulduMu = false; 
  tft.fillRect(0, 0, tft.width(), 80, TFT_BLUE);
  tft.setTextColor(TFT_WHITE); tft.setTextSize(3); tft.setTextDatum(MC_DATUM);
  tft.drawString("HEDEF VURULDU!", tft.width()/2, 40);
  
  // GÜNCELLEME 1: Sadece buzzer ile ikaz veriyor
  for(int i=0; i<6; i++) {
    tone(BUZZER_PIN, 2000, 150); delay(150);
    tone(BUZZER_PIN, 2500, 150); delay(150);
  }
}

